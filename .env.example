# Kith environment configuration — copy to .env and fill in real values.
# Secrets (DB_PASSWORD, JWT_SECRET, FIELD_ENCRYPTION_KEY) must NEVER be committed.

NODE_ENV=production
PORT=3000

# When serving over plain HTTP (e.g. a LAN/IP-only instance with no TLS proxy),
# set this to false so cookies aren't marked Secure and the CSP doesn't force
# https:// on assets. Leave true (the default in production) when behind TLS.
BEHIND_TLS=true

# --- Database -------------------------------------------------------------
# Default: the bundled MariaDB container that ships in docker-compose.yml.
# The `bundled-db` compose profile turns it on; DB_HOST=db reaches it on the
# compose network. Data persists in the kith_db_data named volume and the
# database is never exposed on the host.
COMPOSE_PROFILES=bundled-db
DB_HOST=db
DB_PORT=3306
DB_USER=kith
DB_PASSWORD=changeme
DB_NAME=kith
# The bundled DB runs on a private compose network without TLS.
DB_SSL=false

# To use an EXTERNAL MariaDB/MySQL server instead:
#   COMPOSE_PROFILES=            # (empty — disables the bundled db service)
#   DB_HOST=your-db-host
#   DB_SSL=true                  # verify certs; DB_SSL_CA=<path> for a private
#                                # CA, or DB_SSL_INSECURE=true for
#                                # encrypted-but-unverified (self-signed certs)
# ---------------------------------------------------------------------------

# Auth — JWT signing secret. In NODE_ENV=production the server REFUSES to start
# if this is missing or still a "changeme" placeholder.
JWT_SECRET=changeme-use-a-real-secret

# Confidential-field encryption — 32-byte key, base64-encoded (44 chars).
# Generate: openssl rand -base64 32
# BACK IT UP separately from your database backups. Losing it makes all
# encrypted confidential data permanently unrecoverable.
FIELD_ENCRYPTION_KEY=changeme-32-byte-base64-key

# Media & uploads — point MEDIA_PATH at a mounted volume for photos/videos.
MEDIA_PATH=/media
UPLOAD_PATH=/app/uploads
MAX_UPLOAD_SIZE=52428800
IMPORT_MAX_UPLOAD_SIZE=2147483648

# Base URL used for links in emails/push notifications.
APP_URL=https://kith.example.com

# Optional self-hosted geocoder (Photon) for address/event geocoding on the map.
# Leave empty to use the bundled city-level dataset only.
# PHOTON_URL=http://your-photon-host:2322

# Notifications & email delivery (runtime-only; not secrets except SMTP creds).
# If NOTIFY_WEBHOOK is set, digest/nudge emails are POSTed as JSON
# {to,subject,html,text} to it instead of going out via direct SMTP.
NOTIFY_WEBHOOK=
# Direct SMTP (used only when NOTIFY_WEBHOOK is empty).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM=Kith <kith@example.com>

# CardDAV/CalDAV push (optional). One-way sync of non-confidential contacts +
# calendar to any DAV server; Kith's DB stays the source of truth.
# Enable only once DAV_PASS is provisioned.
DAV_URL=http://your-dav-host:5232
DAV_USER=kith
# DAV_PASS=
DAV_SYNC_ENABLED=false
