# ── Docker Compose ──────────────────────────
SERVICE=kith
EXTERNAL_PORT=8084
RESTART_POLICY=always
URL=kith.example.com

# ── GitLab Container Registry ───────────────
# Set to your GitLab registry image path, e.g.:
# registry.gitlab.com/yourgroup/yourrepo/kith:latest
REGISTRY_IMAGE=kith-local:latest

# ── Database (external MariaDB) ─────────────
DB_HOST=db-host
DB_PORT=3306
DB_USER=kith
DB_PASSWORD=changeme
DB_NAME=kith

# ── Auth ────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-secret

# ── Initial Admin User (created on first boot if no users exist) ─
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@kith.local
ADMIN_PASSWORD=changeme
