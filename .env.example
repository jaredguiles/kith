# Kith environment configuration — copy to .env and fill in real values.
# Secrets (DB_PASSWORD, JWT_SECRET, FIELD_ENCRYPTION_KEY) must NEVER be committed.

NODE_ENV=production
PORT=3000

# Database — MariaDB (production: the database server VM; dev: throwaway container from docker-compose.dev.yml)
DB_HOST=db-host-here
DB_PORT=3306
DB_USER=kith
DB_PASSWORD=changeme
DB_NAME=kith
DB_SSL=true

# Auth — JWT signing secret. In NODE_ENV=production the server REFUSES to start
# if this is missing or still a "changeme" placeholder.
JWT_SECRET=changeme-use-a-real-secret

# Spicy-field encryption — 32-byte key, base64-encoded (44 chars).
# Generate: openssl rand -base64 32
# Back it up in a secrets manager SEPARATELY from DB backups. Losing it makes all
# encrypted spicy data permanently unrecoverable.
FIELD_ENCRYPTION_KEY=changeme-32-byte-base64-key

# Media & uploads
MEDIA_PATH=/media
UPLOAD_PATH=/app/uploads
MAX_UPLOAD_SIZE=52428800
IMPORT_MAX_UPLOAD_SIZE=2147483648
