# Kith environment configuration — copy to .env and fill in real values.
# Secrets (DB_PASSWORD, JWT_SECRET, FIELD_ENCRYPTION_KEY) must NEVER be committed.

NODE_ENV=production
PORT=3000

# Database — MariaDB (production: the database server VM; dev: throwaway container from docker-compose.dev.yml)
DB_HOST=db-host-here
DB_PORT=3306
DB_USER=kith
DB_PASSWORD=changeme
DB_NAME=kith
DB_SSL=true

# Auth — JWT signing secret. In NODE_ENV=production the server REFUSES to start
# if this is missing or still a "changeme" placeholder.
JWT_SECRET=changeme-use-a-real-secret

# Spicy-field encryption — 32-byte key, base64-encoded (44 chars).
# Generate: openssl rand -base64 32
# Back it up in a secrets manager SEPARATELY from DB backups. Losing it makes all
# encrypted spicy data permanently unrecoverable.
FIELD_ENCRYPTION_KEY=changeme-32-byte-base64-key

# Media & uploads
MEDIA_PATH=/media
UPLOAD_PATH=/app/uploads
MAX_UPLOAD_SIZE=52428800
IMPORT_MAX_UPLOAD_SIZE=2147483648

# Notifications & email delivery (runtime-only; not secrets except SMTP creds).
# Base URL used for links in emails/push.
APP_URL=https://kith.example.com
# If set, digest/nudge emails are POSTed as JSON {to,subject,html,text} to this
# n8n webhook instead of going out via direct SMTP. Leave empty to use SMTP.
N8N_NOTIFY_WEBHOOK=
# Direct SMTP (used only when N8N_NOTIFY_WEBHOOK is empty). Real SMTP_USER/PASS
# come later from a secrets manager -> .secrets; leave commented until then.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM=Kith <kith@example.com>

# CardDAV/CalDAV push (Kith -> Radicale). One-way sync of SFW contacts +
# calendar to a standalone Radicale server; Kith's DB stays source of truth.
# DAV_PASS is a SECRET -> a secrets manager -> .secrets; leave empty/commented here.
# Enable only once DAV_PASS is provisioned.
DAV_URL=http://radicale-host:5232
DAV_USER=kith
# DAV_PASS=            # from a secrets manager -> .secrets (bcrypt htpasswd on Radicale side)
DAV_SYNC_ENABLED=false
